# ─── LLM API Keys ───────────────────────────────────────
# At least one key is required for summarization / Q&A features.
# The scraper works without any key — LLM features just get skipped.

GOOGLE_API_KEY=your-gemini-api-key-here
GROQ_API_KEY=your-groq-api-key-here

# ─── Optional ───────────────────────────────────────────
# USER_AGENT=WebScraper/1.0
# REQUEST_TIMEOUT=30
